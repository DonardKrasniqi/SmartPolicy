generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String            @id @default(uuid())
  name             String
  email            String            @unique
  role             String
  passwordHash     String
  active           Boolean           @default(true)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  createdPolicies  Policy[]          @relation("PolicyCreator")
  approvedPolicies Policy[]          @relation("PolicyApprover")
  acknowledgements Acknowledgement[]
  auditLogs        AuditLog[]
}

model Policy {
  id               String            @id @default(uuid())
  title            String
  description      String
  content          String
  status           String
  version          String
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  publishedAt      DateTime?
  approvedAt       DateTime?
  createdBy        String?
  approvedBy       String?
  creator          User?             @relation("PolicyCreator", fields: [createdBy], references: [id])
  approver         User?             @relation("PolicyApprover", fields: [approvedBy], references: [id])
  versions         PolicyVersion[]
  acknowledgements Acknowledgement[]
}

model PolicyVersion {
  id          String   @id @default(uuid())
  policyId    String
  version     String
  title       String
  description String
  content     String
  archivedAt  DateTime @default(now())
  archivedBy  String?
  changeType  String   @default("minor")
  changeSummary String @default("")
  policy      Policy   @relation(fields: [policyId], references: [id], onDelete: Restrict)
}

model Acknowledgement {
  id            String   @id @default(uuid())
  policyId      String
  policyTitle   String
  policyVersion String
  userId        String
  userName      String
  userEmail     String
  ipAddress     String
  userAgent     String
  signedAt      DateTime @default(now())
  evidence      Json
  auditLogId    String?
  policy        Policy   @relation(fields: [policyId], references: [id], onDelete: Restrict)
  user          User     @relation(fields: [userId], references: [id], onDelete: Restrict)
}

model AuditLog {
  id         String   @id @default(uuid())
  timestamp  DateTime @default(now())
  userId     String?
  userName   String
  userRole   String
  action     String
  entity     String
  entityId   String?
  ipAddress  String
  userAgent  String
  metadata   Json
  user       User?    @relation(fields: [userId], references: [id], onDelete: Restrict)
}
